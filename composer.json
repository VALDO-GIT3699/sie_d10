{
    "name": "drupal/sie_d10",
    "description": "Drupal 10 project (clean installation)",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "homepage": "https://www.drupal.org/project/drupal",

    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        }
    ],

    "require": {
        "composer/installers": "^2.0",
        "dompdf/dompdf": "^2.0",
        "drupal/backup_migrate": "^5.0",
        "drupal/bootstrap": "^3.27",
        "drupal/bootstrap4": "^3.0",
        "drupal/captcha": "^1.9",
        "drupal/charts": "^5.2",
        "drupal/charts_google": "^5.2",
        "drupal/charts_highcharts": "^5.2",
        "drupal/core-composer-scaffold": "10.6.12",
        "drupal/core-project-message": "10.6.12",
        "drupal/core-recommended": "10.6.12",
        "drupal/core-vendor-hardening": "10.6.12",
        "drupal/csv_serialization": "^4.0",
        "drupal/ctools": "^4.0",
        "drupal/date_popup": "^1.3",
        "drupal/devel": "^5.0",
        "drupal/devel_entity_updates": "^5.0",
        "drupal/easy_breadcrumb": "^2.0",
        "drupal/entity_print": "^2.11",
        "drupal/fieldblock": "^2.2",
        "drupal/google_analytics": "^4.0",
        "drupal/gtm": "^1.10",
        "drupal/libraries": "^4.1",
        "drupal/menu_block": "^1.10",
        "drupal/panels": "^4.9",
        "drupal/pathauto": "^1.11",
        "drupal/phpmailer_smtp": "^2.0",
        "drupal/simple_menu_icons": "^3.0",
        "drupal/smtp": "^1.0",
        "drupal/stable": "^2.1",
        "drupal/token": "^1.11",
        "drupal/transliterate_filenames": "^2.0",
        "drupal/twig_tweak": "^3.2",
        "drupal/video": "^3.0.5",
        "drupal/webform": "^6.2",
        "drush/drush": "^12.5",
        "league/csv": "^9.10",
        "phpmailer/phpmailer": "^6.6"
    },

    "conflict": {
        "drupal/drupal": "*",
        "drupal/classy": "*"
    },

    "minimum-stability": "stable",
    "prefer-stable": true,

    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "composer/installers": true,
            "drupal/core-composer-scaffold": true,
            "drupal/core-project-message": true,
            "drupal/core-vendor-hardening": true
        }
    },

    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "./"
            }
        },

        "installer-paths": {
            "core": ["type:drupal-core"],
            "libraries/{$name}": ["type:drupal-library"],
            "modules/contrib/{$name}": ["type:drupal-module"],
            "profiles/contrib/{$name}": ["type:drupal-profile"],
            "themes/contrib/{$name}": ["type:drupal-theme"],
            "drush/Commands/contrib/{$name}": ["type:drupal-drush"],
            "modules/custom/{$name}": ["type:drupal-custom-module"],
            "profiles/custom/{$name}": ["type:drupal-custom-profile"],
            "themes/custom/{$name}": ["type:drupal-custom-theme"]
        }
    }
}
